# ── Site ────────────────────────────────────────────────────────────────
# Canonical origin, no trailing slash. Used for SEO, sitemap, RSS, OG.
NEXT_PUBLIC_SITE_URL=https://theappsthere.com

# ── Paddle Billing (checkout) ───────────────────────────────────────────
# "sandbox" while testing, "production" when live.
NEXT_PUBLIC_PADDLE_ENV=sandbox
# Client-side token: Paddle dashboard → Developer tools → Authentication.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Price ID of the Lumiso Transcribe Pro one-time price (pri_...).
NEXT_PUBLIC_PADDLE_PRICE_LUMISO_PRO=

# ── Paddle Billing (server) ─────────────────────────────────────────────
# API key (Developer tools → Authentication). Used to resolve buyer emails
# and to look up purchases for license recovery.
PADDLE_API_KEY=
# Webhook endpoint secret (Developer tools → Notifications → your webhook).
PADDLE_WEBHOOK_SECRET=

# ── Licensing ───────────────────────────────────────────────────────────
# Base64 raw Ed25519 private key that signs license keys.
# Generate with: node scripts/license.mjs keygen
# The matching PUBLIC key must be embedded in the app (LicenseVerifier).
# NEVER commit the real value.
LICENSE_SIGNING_PRIVATE_KEY=

# ── Email delivery ──────────────────────────────────────────────────────
# Resend API key for license emails. Leave empty to log emails to the
# server console (dry-run) instead of sending.
RESEND_API_KEY=
LICENSE_EMAIL_FROM="TheAppsThere <licenses@theappsthere.com>"

# ── Newsletter (optional) ───────────────────────────────────────────────
# POST target that receives {"email": "..."} on signup.
NEWSLETTER_WEBHOOK_URL=

# ── Downloads ───────────────────────────────────────────────────────────
# Override the Lumiso Transcribe download URL (e.g. a GitHub release).
NEXT_PUBLIC_DOWNLOAD_URL_LUMISO=
